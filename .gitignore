# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
package-lock.json
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sqlite
*.db
*.db-wal
*.db-shm
/lib/lexicons

# Local multi-agent bug-bash setup (#106). The dev network file holds
# in-process PDS URLs + plaintext test passwords, and the agent session
# directory holds OAuth `did` cookies — neither belongs in git.
/.smellgate-dev-env.json
/.smellgate-agent-sessions/
