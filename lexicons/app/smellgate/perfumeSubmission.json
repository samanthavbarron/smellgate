{
  "id": "app.smellgate.perfumeSubmission",
  "description": "A user-authored proposal to add a perfume to the canonical catalog. Curators review each submission and either publish a corresponding app.smellgate.perfume record (tracked via app.smellgate.perfumeSubmissionResolution) or reject it. There is no status field on the submission itself; resolution is tracked by a separate curator-authored record so submissions remain append-only from the submitter's perspective.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "house", "notes", "createdAt"],
        "properties": {
          "name": {
            "type": "string"
          },
          "house": {
            "type": "string",
            "description": "The perfume house / brand."
          },
          "creator": {
            "type": "string",
            "description": "The perfumer / nose, when known."
          },
          "releaseYear": {
            "type": "integer"
          },
          "notes": {
            "type": "array",
            "minLength": 1,
            "description": "Free-form tag strings. Normalized lowercase.",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "description": {
            "type": "string"
          },
          "rationale": {
            "type": "string",
            "minLength": 1,
            "description": "Optional note from the submitter to the curator."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  },
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1
}
