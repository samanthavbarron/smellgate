# Reproducibility: never ship workspace-local state into the image.
# `node_modules` and `.next` are rebuilt inside the image; everything else
# below is either secret, dev-only, or irrelevant to a production runtime.

# Node / pnpm
node_modules
.pnp
.pnp.*
.yarn

# Next.js build output (rebuilt in the `build` stage)
.next
out
build

# Environment files — secrets travel via `flyctl secrets`, never the image
.env
.env.*

# SQLite state — the production DB lives on a Fly volume, not in the image
*.db
*.db-wal
*.db-shm

# Tests, coverage, CI, and editor/agent workspaces
tests
coverage
.github
.vscode
.idea
.claude

# Local multi-agent dev artifacts (see .gitignore)
.smellgate-dev-env.json
.smellgate-agent-sessions

# Git metadata — container doesn't need history
.git
.gitignore
.gitattributes

# Docs and misc
README.md
CONTRIBUTING.md
AGENTS.md
PLAN.md
LICENSE
docs
*.md
*.log
.DS_Store

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Generated lexicons are gitignored but ARE needed at build time; they're
# regenerated by `pnpm build:lex` in the Dockerfile's build stage, so any
# locally-generated copy should NOT be COPY'd into the image.
lib/lexicons
